# HisabClub Configuration
# Copy to .env and fill in your values

# Database
DATABASE_URL=postgresql+asyncpg://hisabclub:hisabclub_dev@localhost:5433/hisabclub
DATABASE_URL_SYNC=postgresql://hisabclub:hisabclub_dev@localhost:5433/hisabclub
POSTGRES_USER=hisabclub
POSTGRES_PASSWORD=hisabclub_dev
POSTGRES_DB=hisabclub

# Redis
REDIS_URL=redis://localhost:6380/0

# Auth
SECRET_KEY=change-me-to-a-random-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# File Storage
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# LLM (disabled by default)
LLM_ENABLED=false
LLM_BASE_URL=http://localhost:8080/v1
LLM_API_KEY=
LLM_MODEL=qwq-32b
CATEGORY_WEB_LOOKUP_ENABLED=false
CATEGORY_WEB_LOOKUP_TIMEOUT_SEC=5
# For OpenRouter: LLM_BASE_URL=https://openrouter.ai/api/v1

# Privacy guardrails (recommended ON)
LOCAL_ONLY_MODE=true
LOCAL_ALLOWED_ROOTS=/home/ankit/Documents
LOCAL_ALLOWED_LLM_HOSTS=localhost,127.0.0.1,::1

# App
APP_NAME=HisabClub
DEBUG=true
HOST=0.0.0.0
PORT=8000

# Gmail OAuth (required for Gmail import)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:8000/api/v1/gmail/callback
