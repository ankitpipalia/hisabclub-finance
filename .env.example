# HisabClub Configuration
# Copy to .env and fill in your values

# Database
DATABASE_URL=postgresql+asyncpg://hisabclub:hisabclub_dev@localhost:6543/hisabclub
DATABASE_URL_SYNC=postgresql://hisabclub:hisabclub_dev@localhost:6543/hisabclub
DB_SET_ROLE_ON_CONNECT=true
DB_RLS_ROLE=hisabclub_rls
POSTGRES_USER=hisabclub
POSTGRES_PASSWORD=hisabclub_dev
POSTGRES_DB=hisabclub

# Redis
REDIS_URL=redis://localhost:6769/0
JOB_RUNNER_ENABLED=true
JOB_RUNNER_POLL_SECONDS=1.0
JOB_RUNNER_DLQ_RETRY_ENABLED=true

# Auth
SECRET_KEY=change-me-to-a-random-secret-key-in-production
DATA_ENCRYPTION_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# File Storage
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50
MAX_PDF_PAGES=200

# LLM (disabled by default)
LLM_ENABLED=false
LLM_BASE_URL=http://127.0.0.1:8097/v1
LLM_API_KEY=
LLM_MODEL=Qwen3.6-27B-Q5_K_S.gguf
LLM_STARTUP_VALIDATION=false
LLM_REQUIRED_FOR_BOOT=false
LLM_SMALL_MODEL=
LLM_LARGE_MODEL=
LLM_RUNTIME_LABEL=shared-local-llm
LLM_ROUTER_ENABLED=true
LLM_JSON_MODE=true
LLM_VISION_ENABLED=false
LLM_VISION_BASE_URL=http://127.0.0.1:8096/v1
LLM_VISION_API_KEY=
LLM_VISION_MODEL=Qwen3-VL-8B-Instruct-Q4_K_M.gguf
LLM_VISION_STATEMENT_EXTRACTION_ENABLED=false
LLM_VISION_STATEMENT_PRIMARY=false
LLM_VISION_RENDER_DPI=180
LLM_VISION_PAGE_LIMIT=24
LLM_PROMPT_VERSION_STATEMENT_EXTRACTION=statement_extraction_v2
LLM_PROMPT_VERSION_STATEMENT_CLASSIFICATION=statement_classification_v2
LLM_ITERATIVE_CHUNK_CHARS=5200
LLM_ITERATIVE_OVERLAP_LINES=6
LLM_MAX_CHUNK_COUNT=12
PROMOTION_CONFIDENCE_THRESHOLD=0.75
MIN_YIELD_RATE_FOR_AUTO_PROMOTION=0.55
REQUIRE_CC_INTEGRITY_OK_FOR_AUTO_PROMOTION=false
SMS_TYPED_VALIDATION_ENABLED=false
EXTRACTION_UNIFIED_VALIDATION_ENABLED=false
EXTRACTION_REVIEW_KEEPS_AMBIGUOUS_DIRECTION=false
SANITIZER_PRESERVE_SHORT_REFS=false
CATEGORY_WEB_LOOKUP_ENABLED=false
CATEGORY_WEB_LOOKUP_TIMEOUT_SEC=5
OCR_ENABLED=false
OCR_BASE_URL=http://127.0.0.1:8095/v1
LLM_OCR_BASE_URL=http://127.0.0.1:8095/v1
OCR_API_KEY=
OCR_MODEL=glm-4.1v-9b-thinking
OCR_RENDER_DPI=200
OCR_PAGE_LIMIT=24
OCR_MIN_TEXT_CHARS_PER_PAGE=60
OCR_MIN_ALPHA_RATIO=0.15
OCR_TIMEOUT_SEC=300
OCR_MAX_ATTEMPTS=2
# Shared local text runtime is managed in /home/ankit/Documents/local-llm/shared-local-llm.env.
# Shared runtime control commands:
#   bash /home/ankit/Documents/local-llm/shared-local-llm.sh start qwen
#   bash /home/ankit/Documents/local-llm/shared-local-llm.sh status qwen
# If you enable multimodal parsing, keep LLM_VISION_* aligned with the shared vision endpoint on :8096.
# Set LLM_VISION_STATEMENT_PRIMARY=true to make PDF page-image extraction the primary path.
# For OpenRouter: LLM_BASE_URL=https://openrouter.ai/api/v1

# Privacy guardrails (recommended ON)
LOCAL_ONLY_MODE=true
LOCAL_ALLOWED_ROOTS=/app/uploads,/home/ankit/Documents,/home/ankit/Downloads
LOCAL_ALLOWED_LLM_HOSTS=localhost,127.0.0.1,::1
LOCAL_DOCUMENTS_ROOT=/home/ankit/Documents
LOCAL_DOWNLOADS_ROOT=/home/ankit/Downloads
COLD_STORAGE_ENABLED=true
COLD_STORAGE_DIR=./uploads/cold

# App
APP_NAME=HisabClub
DEBUG=true
HOST=0.0.0.0
PORT=8356

# Gmail OAuth (required for Gmail import)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=https://hisabclub-dev-api.ankit-tech.store/api/v1/gmail/callback

# Password reset / outbound email
WEB_BASE_URL=https://hisabclub-dev-web.ankit-tech.store
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USERNAME=resend
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@notify-hisabclub.ankit-tech.store
SMTP_FROM_NAME=HisabClub
SMTP_USE_STARTTLS=true
SMTP_USE_SSL=false
