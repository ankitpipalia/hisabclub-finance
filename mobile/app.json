{
  "expo": {
    "name": "HisabClub",
    "slug": "hisabclub",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "hisabclub",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1851B2"
    },
    "android": {
      "package": "com.hisabclub.app",
      "adaptiveIcon": {
        "backgroundColor": "#1851B2",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png"
      },
      "permissions": [
        "android.permission.READ_SMS",
        "android.permission.RECEIVE_SMS"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.hisabclub.app",
      "supportsTablet": false,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "HisabClub needs access to your photo library so you can upload statement PDFs and receipts.",
        "NSDocumentsFolderUsageDescription": "HisabClub uses your Documents folder to pick statement PDFs you've saved locally.",
        "NSCameraUsageDescription": "HisabClub can scan receipts and statement pages with your camera (optional).",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false,
          "NSExceptionDomains": {
            "localhost": {
              "NSExceptionAllowsInsecureHTTPLoads": true,
              "NSIncludesSubdomains": true
            },
            "127.0.0.1": {
              "NSExceptionAllowsInsecureHTTPLoads": true,
              "NSIncludesSubdomains": true
            }
          }
        }
      }
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24
          }
        }
      ],
      "expo-sharing",
      [
        "expo-secure-store",
        {
          "configureAndroidBackup": true,
          "faceIDPermission": "Allow HisabClub to use Face ID to unlock saved credentials."
        }
      ],
      "expo-font"
    ],
    "platforms": [
      "android",
      "ios"
    ]
  }
}
